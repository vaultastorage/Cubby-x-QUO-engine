# Copy this file to .env and fill in your values. .env is gitignored — never commit it.

# --- Required ---
CUBBY_API_KEY=your-cubby-api-key-here
QUO_API_KEY=your-quo-openphone-api-key-here

# Your two facility ids from Cubby (Ocean City, Southern), comma-separated.
# Find them via POST /v1/facilities/search, or in the Cubby dashboard URL.
CUBBY_FACILITY_IDS=fac_xxxxxxxxxxx,fac_yyyyyyyyyyy

# --- Optional (sane defaults; change only if needed) ---

# OpenPhone/Quo uses the raw key in the Authorization header. If Quo calls 401,
# uncomment the line below to send "Bearer <key>" instead.
# QUO_AUTH_SCHEME=Bearer 

# Which Quo default field holds the "Name - Unit" string. Default keeps the whole
# string in firstName with lastName blank.
# QUO_NAME_FIELD=firstName

# Where the cursor + id map live (default state.json in the project root).
# STATE_PATH=state.json

# Set to 0 to quiet the diagnostic logging once the sync is stable.
SYNC_DEBUG=1
